<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Acervo - Biblioteca Arruda</title>

    <link rel="stylesheet" href="style.css">
</head>
<body>

<nav>
    <div class="nav-inner">

        <button
            class="menu-toggle"
            id="menu-toggle"
            aria-expanded="false">
            ☰
        </button>

        <div class="menu" id="main-menu">
            <a href="index.html">Início</a>
            <a href="acervo.html">Acervo</a>
            <a href="servico.html">Serviços</a>
        </div>

        <button id="tema-btn">
            🌙
        </button>

    </div>
</nav>

<main class="container">

    <section>

        <h1>📚 Acervo da Biblioteca</h1>

        <p>
            Consulte os livros disponíveis em nosso catálogo.
        </p>

    </section>

    <div class="stats">

        <div class="stat-card">
            <h3>📘 0</h3>
            <p>Livros cadastrados</p>
        </div>

        <div class="stat-card">
            <h3>✅ 0</h3>
            <p>Disponíveis</p>
        </div>

        <div class="stat-card">
            <h3>📕 0</h3>
            <p>Emprestado</p>
        </div>

    </div>

    <section>

        <h2> Pesquisar Livro</h2>

        <input
            type="text"
            id="search"
            placeholder="Digite o título ou autor..."
            style="
                width:100%;
                padding:12px;
                border-radius:8px;
                border:1px solid #ccc;
                margin-top:10px;
            "
        >

    </section>

    <div class="filters">

        <button class="filter-btn active">
            Todos
        </button>

        <button class="filter-btn">
            Ficção
        </button>

        <button class="filter-btn">
            Tecnologia
        </button>

        <button class="filter-btn">
            História
        </button>

        <button class="filter-btn">
            Disponíveis
        </button>

    </div>

    <div class="books-grid">

        <div class="book-card">

            <div class="book-cover">
              📕
            </div>

            <div class="book-info">

                <div class="book-title">
                    Codigo da Vince - Inferno
                </div>

                <div class="book-author">
                    Dan Brown
                </div>

                <span class="book-status available">
                    Disponível
                </span>

            </div>

        </div>

        <section class="add-book">
    <h2>Adicionar Livro</h2>

    <input type="text" id="titulo" placeholder="Título">
    <input type="text" id="autor" placeholder="Autor">

    <button onclick="adicionarLivro()">
        Adicionar
    </button>
</section>

        <footer>
          <p>© 2026 EEPJAP</p>
      
      </footer>
      
      <script src="script.js"></script>
      
      </body>
      </html>

